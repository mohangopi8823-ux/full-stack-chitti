# Backend environment example.
# Copy to backend/.env or backend/.env.local and replace placeholders locally.
# Never commit real service role keys, database URLs, payment secrets, or API keys.

DATABASE_URL=postgresql://user:password@host:5432/database
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-supabase-anon-key
OAUTH_SERVER_URL=https://your-oauth-server.example.com
VITE_APP_ID=your-app-id
# Locally use the values below. On Render, replace them with the two Vercel URLs.
# Comma-separated values are supported when you also want Vercel preview URLs.
FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5175
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
BUILT_IN_FORGE_API_URL=https://your-forge-api.example.com
BUILT_IN_FORGE_API_KEY=your-server-api-key
FAST2SMS_API_KEY=your-fast2sms-api-key
FAST2SMS_OTP_ID=your-fast2sms-otp-template-id
OPENAI_API_KEY=your-openai-api-key
JWT_SECRET=change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me
BACKUP_ADMIN_SECRET=change-me
OWNER_OPEN_ID=your-owner-open-id
PORT=3000
NODE_ENV=development
