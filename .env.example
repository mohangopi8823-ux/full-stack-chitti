# Frontend environment example.
# Copy to .env or .env.local and replace placeholders locally.

VITE_API_URL=https://full-stack-chitti.onrender.com
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-supabase-anon-key
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.example.com
VITE_APP_ID=your-app-id
VITE_FRONTEND_FORGE_API_URL=https://your-frontend-forge-api.example.com
VITE_FRONTEND_FORGE_API_KEY=your-public-frontend-api-key
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=change-me

# Backend CORS origins.
FRONTEND_URL=https://full-stack-chitti.onrender.com
ADMIN_FRONTEND_URL=https://full-stack-chitti.onrender.com

